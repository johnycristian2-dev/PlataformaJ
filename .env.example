# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/plataformaj?schema=public"

# ============================================================
# NEXT AUTH / AUTH.JS v5
# ============================================================
NEXTAUTH_SECRET="replace-with-strong-secret"
NEXTAUTH_URL="http://localhost:3000"

# Auth.js v5 uses AUTH_SECRET instead of NEXTAUTH_SECRET
AUTH_SECRET="replace-with-strong-secret"
AUTH_TRUST_HOST="false"
AUTH_DEBUG="false"

# ============================================================
# UPLOAD / STORAGE (ex: Cloudinary / S3 / Uploadthing)
# ============================================================
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# AWS S3 (alternativa)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="sa-east-1"
# AWS_S3_BUCKET=""

# ============================================================
# STRIPE (pagamentos)
# ============================================================
STRIPE_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
STRIPE_PAYMENT_METHOD_TYPES="card"

# ============================================================
# MERCADO PAGO (alternativa nacional)
# ============================================================
MP_ACCESS_TOKEN=""
MP_PUBLIC_KEY=""

# ============================================================
# EMAIL (ex: Resend / SendGrid / SMTP)
# ============================================================
RESEND_API_KEY=""
EMAIL_FROM="noreply@plataformaj.com"

# SMTP fallback (opcional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Plataforma J"
NEXT_IMAGE_ALLOWED_HOSTS=""
NODE_ENV="development"
